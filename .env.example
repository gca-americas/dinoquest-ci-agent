# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_GENAI_USE_VERTEXAI=True

# ── GitHub (one of the two forms required) ────────────────────────────────────
# Direct value (local dev):
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Secret Manager resource name (Cloud Run):
# GITHUB_TOKEN_SECRET=projects/your-project/secrets/github-token/versions/latest

# ── Slack post-back (one of the two forms required) ───────────────────────────
# Direct value (local dev):
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
# Secret Manager resource name (Cloud Run):
# SLACK_WEBHOOK_SECRET=projects/your-project/secrets/ci-slack-webhook/versions/latest

# ── A2A: DinoAgent URL (required for Behavior B — cross-agent skill teaching) ─
DINOAGENT_URL=https://dino-agent-xxx-uc.a.run.app

# ── Pub/Sub event bus (required for dino-theater visualization) ───────────────
HARNESS_EVENTS_TOPIC=projects/your-gcp-project-id/topics/harness-events
CLOUD_BUILD_REPO=weimeilin79-dinoquest-io

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Skips Cloud Build tests/build (retags pre-built image), image verify, pr diff fetch
# Pre-built images required: app:level_2 and app:incident_solution in Artifact Registry
# See demo-setup.md for full instructions
DEMO_MODE=false

# ── Optional overrides (defaults shown) ───────────────────────────────────────
# CLOUD_RUN_REGION=us-central1
# ARTIFACT_REGISTRY_REPO=dinoquest
# GITHUB_OWNER=weimeilin79
# GITHUB_REPO=dinoquest-io
# PORT=8080
